# EditorConfig

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python files
[*.py]
# Black formatting (line-length = 88)
max_line_length = 88
indent_style = space
indent_size = 4

# YAML/JSON files
[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Shell scripts
[*.sh]
indent_style = tab

# Windows batch files
[*.bat]
end_of_line = crlf

# Git configuration
[*.gitignore]
insert_final_newline = false

# Requirements files
[requirements*.txt]
indent_style = space
indent_size = 4

# Dockerfile
[Dockerfile]
indent_style = space
indent_size = 4
