# FastAPI backend configuration
#
# Model artifact created by:
#   python scripts/train_spam_detector.py --output models/spam_detector.joblib

MODEL_PATH=models/spam_detector.joblib

# MongoDB settings
MONGO_URI=mongodb://localhost:27017
MONGO_DB=spam_detector
MONGO_COLLECTION=predictions

# Logging
LOG_LEVEL=INFO

# Database writes (set to false to run without MongoDB)
ENABLE_DB_WRITES=false

# Stats window (hours)
STATS_LAST_HOURS=24

# Model label mapping (spam=1, not_spam=0)
MODEL_SPAM_LABEL=1

# ============================================
# Gmail Integration (optional)
# ============================================
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=gmail_token.json
GMAIL_CHECK_INTERVAL=300
GMAIL_LABEL_SPAM=SPAM
GMAIL_LABEL_SAFE=INBOX

# Prediction API (for Gmail integration)
PREDICTION_API_URL=http://localhost:8000
PREDICTION_API_KEY=

