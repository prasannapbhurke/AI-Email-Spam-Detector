# FastAPI backend configuration
#
# Model artifact created by:
#   python scripts/train_spam_detector.py --output models/spam_detector.joblib

MODEL_PATH=models/spam_detector.joblib

MONGO_URI=mongodb://localhost:27017
MONGO_DB=spam_detector
MONGO_COLLECTION=predictions

LOG_LEVEL=INFO
ENABLE_DB_WRITES=true

STATS_LAST_HOURS=24
MODEL_SPAM_LABEL=1

